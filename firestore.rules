rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      // Can only read your own doc
      allow read: if request.auth != null && request.auth.uid == userId;

      // Can only create your own doc, must start as free or pro
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.tier in ['free', 'pro'];

      // Updates: authenticated user on own doc, with restrictions
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    // Tier can stay the same or upgrade (free → early_access/pro), never downgrade
                    && (
                      request.resource.data.tier == resource.data.tier
                      || (resource.data.tier == 'free' && request.resource.data.tier in ['early_access', 'pro'])
                    )
                    // Lifetime scan count can only go up (never reset)
                    && request.resource.data.scanUsage.lifetimeCount >= resource.data.scanUsage.lifetimeCount
                    // Monthly count: can go up OR reset to 0 (monthly reset)
                    && (
                      request.resource.data.scanUsage.count >= resource.data.scanUsage.count
                      || request.resource.data.scanUsage.count == 0
                    );

      // No deletes
      allow delete: if false;
    }

    // --- Access Codes ---
    match /accessCodes/{codeId} {
      // Any authenticated user can read codes (needed for redemption transaction)
      allow read: if request.auth != null;

      // Updates: only allow incrementing currentUses + adding to redeemedBy
      // Cannot change code metadata (isActive, maxUses, scanLimit, tier, code)
      allow update: if request.auth != null
                    && request.resource.data.currentUses == resource.data.currentUses + 1
                    && request.resource.data.isActive == resource.data.isActive
                    && request.resource.data.code == resource.data.code
                    && request.resource.data.maxUses == resource.data.maxUses
                    && request.resource.data.scanLimit == resource.data.scanLimit
                    && request.resource.data.tier == resource.data.tier;

      // No create or delete (admin only via Firebase Console)
      allow create, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
