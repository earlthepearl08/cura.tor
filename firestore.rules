rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      // Can only read your own doc
      allow read: if request.auth != null && request.auth.uid == userId;

      // Can only create your own doc, must start as free or pro
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.tier in ['free', 'pro'];

      // Updates: authenticated user on own doc, with restrictions
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    // Tier can stay the same or upgrade (free → early_access/pro), never downgrade
                    && (
                      request.resource.data.tier == resource.data.tier
                      || (resource.data.tier == 'free' && request.resource.data.tier in ['early_access', 'pro'])
                    )
                    // Lifetime scan count can only go up (never reset)
                    && request.resource.data.scanUsage.lifetimeCount >= resource.data.scanUsage.lifetimeCount
                    // Monthly count: can go up OR reset to 0 (monthly reset)
                    && (
                      request.resource.data.scanUsage.count >= resource.data.scanUsage.count
                      || request.resource.data.scanUsage.count == 0
                    );

      // No deletes
      allow delete: if false;
    }

    // --- Access Codes ---
    match /accessCodes/{codeId} {
      // Any authenticated user can read codes (needed for redemption transaction)
      allow read: if request.auth != null;

      // Updates: only allow incrementing currentUses + adding to redeemedBy
      // Cannot change code metadata (isActive, maxUses, scanLimit, tier, code)
      allow update: if request.auth != null
                    && request.resource.data.currentUses == resource.data.currentUses + 1
                    && request.resource.data.isActive == resource.data.isActive
                    && request.resource.data.code == resource.data.code
                    && request.resource.data.maxUses == resource.data.maxUses
                    && request.resource.data.scanLimit == resource.data.scanLimit
                    && request.resource.data.tier == resource.data.tier;

      // No create or delete (admin only via Firebase Console)
      allow create, delete: if false;
    }

    // --- Organizations (Enterprise) ---
    match /organizations/{orgId} {
      // Helper: caller is a member of this org
      function isMember() {
        return request.auth != null
               && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
      }

      // Read org metadata if member; writes only via Admin SDK
      allow read: if isMember();
      allow write: if false;

      // Members subcollection — read if member, writes only via Admin SDK
      match /members/{uid} {
        allow read: if isMember();
        allow write: if false;
      }

      // Contacts subcollection — read/write if member (client SDK for performance)
      match /contacts/{contactId} {
        allow read, write: if isMember();
      }

      // Folders subcollection — read/write if member
      match /folders/{folderId} {
        allow read, write: if isMember();
      }

      // Batches subcollection — read/write if member
      match /batches/{batchId} {
        allow read, write: if isMember();
      }

      // Invites subcollection — read if member; writes only via Admin SDK
      match /invites/{code} {
        allow read: if isMember();
        allow write: if false;
      }
    }

    // --- Enterprise Requests ---
    match /enterpriseRequests/{requestId} {
      // Any signed-in user can create a request for themselves.
      // Locked down: exact allowed fields, status must be 'pending', size caps
      // to prevent DoS via huge strings or unexpected fields.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasOnly([
                      'uid', 'email', 'displayName', 'orgName',
                      'teamSize', 'contactEmail', 'notes',
                      'status', 'createdAt'
                    ])
                    && request.resource.data.orgName is string
                    && request.resource.data.orgName.size() > 0
                    && request.resource.data.orgName.size() <= 200
                    && request.resource.data.contactEmail is string
                    && request.resource.data.contactEmail.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() <= 200
                    && request.resource.data.notes is string
                    && request.resource.data.notes.size() <= 2000
                    && request.resource.data.teamSize is int
                    && request.resource.data.teamSize >= 1
                    && request.resource.data.teamSize <= 100000;

      // No reads/updates/deletes from the client — admin list/approve/reject go through the API
      allow read, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
