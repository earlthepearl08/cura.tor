# Google API Key — used server-side only (Cloud Vision + Gemini)
# Get your free API key from: https://aistudio.google.com/apikey
# No VITE_ prefix = NOT exposed to browser bundle
GOOGLE_API_KEY=your_api_key_here
GEMINI_API_KEY=your_api_key_here

# Google OAuth Client ID (required for Google Drive sync)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Stripe — Client-side (VITE_ prefix = exposed to browser, safe for publishable keys)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PIONEER_MONTHLY_PRICE_ID=price_xxx
VITE_STRIPE_PIONEER_YEARLY_PRICE_ID=price_xxx
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_xxx

# Stripe — Server-side (set in Vercel dashboard, NOT committed to git)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PIONEER_PRICE_IDS=price_xxx,price_xxx
# STRIPE_PRO_PRICE_IDS=price_xxx,price_xxx

# Firebase Admin — Server-side (for Stripe webhook to write to Firestore)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
